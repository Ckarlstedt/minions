# Copy to `.env` and adjust. `.env` is gitignored — never commit secrets.
# Precedence: process environment variables > .env > built-in defaults.

# OpenAI-compatible endpoint the minion talks to (omlx, vLLM, Ollama, LM Studio, ...)
MINIONS_BASE_URL=http://127.0.0.1:8000/v1

# Model id exactly as the server advertises it (`minions doctor` lists what it found)
MINIONS_MODEL=gpt-oss-20b-MXFP4-Q8
#MINIONS_MODEL=GLM-4.7-Flash-6bit

# API key for the server, if it requires one.
# If unset, minions tries to discover the key from an omlx settings file.
#MINIONS_API_KEY=
#MINIONS_OMLX_SETTINGS_PATH=~/.omlx/settings.json

# Budgets
#MINIONS_MAX_STEPS=16                  # tool calls per investigation
#MINIONS_CONTEXT_TOKEN_LIMIT=24000     # force-finish before the server's context cap
#MINIONS_MAX_TOOL_OUTPUT_CHARS=8000    # per-tool-result truncation
#MINIONS_MAX_COMPLETION_TOKENS=4096    # per-call completion cap (includes reasoning tokens)

# Sampling / transport
#MINIONS_TEMPERATURE=0.2
#MINIONS_REQUEST_TIMEOUT=180

# Where run traces are written (never inside the investigated repository)
#MINIONS_STATE_DIR=~/.local/state/minions
